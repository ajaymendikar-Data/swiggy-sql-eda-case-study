-- kpi-- 
-- 1. Total Orders

SELECT COUNT(*) AS total_orders
FROM fact_swiggy_orders;

-- 2. Total Revenue (INR Million)
SELECT 
    ROUND(SUM(price)/1000000, 2) AS total_revenue_million
FROM fact_swiggy_orders;

-- 3. Average Dish Price

SELECT 
    ROUND(AVG(price), 2) AS avg_dish_price
FROM fact_swiggy_orders;

-- 4. Average Rating 

SELECT 
    ROUND(AVG(rating), 2) AS avg_rating
FROM fact_swiggy_orders;


-- 1. 1. Monthly Order Trends

SELECT 
    d.year,
    d.month,
    d.month_name,
    COUNT(*) AS total_orders
FROM fact_swiggy_orders f
JOIN dim_date d 
    ON f.date_id = d.date_id
GROUP BY d.year, d.month, d.month_name
ORDER BY d.year, d.month;

-- 2. Quarterly Order Trends

SELECT 
    d.year,
    d.quarter,
    COUNT(*) AS total_orders
FROM fact_swiggy_orders f
JOIN dim_date d 
    ON f.date_id = d.date_id
GROUP BY d.year, d.quarter
ORDER BY d.year, d.quarter;

-- 3. Year-wise Growth

SELECT 
    d.year,
    COUNT(*) AS total_orders,
    LAG(COUNT(*)) OVER (ORDER BY d.year) AS prev_year_orders,
    
    ROUND(
        ((COUNT(*) - LAG(COUNT(*)) OVER (ORDER BY d.year)) 
        / LAG(COUNT(*)) OVER (ORDER BY d.year)) * 100, 
    2) AS growth_percentage

FROM fact_swiggy_orders f
JOIN dim_date d 
    ON f.date_id = d.date_id

GROUP BY d.year
ORDER BY d.year;

-- 4. Day-of-Week Patterns

SELECT 
    DAYNAME(d.full_date) AS day_name,
    COUNT(*) AS total_orders
FROM fact_swiggy_orders f
JOIN dim_date d 
    ON f.date_id = d.date_id
GROUP BY DAYNAME(d.full_date)
ORDER BY total_orders DESC;

-- Location-Based Analysis 

-- 1. Top 10 Cities by Order Volume 

SELECT 
    l.city,
    COUNT(*) AS total_orders
FROM fact_swiggy_orders f
JOIN dim_location l 
    ON f.location_id = l.location_id
GROUP BY l.city
ORDER BY total_orders DESC
LIMIT 10;

-- 2. Revenue Contribution by States

SELECT 
    l.state,
    ROUND(SUM(f.price), 2) AS total_revenue
FROM fact_swiggy_orders f
JOIN dim_location l 
    ON f.location_id = l.location_id
GROUP BY l.state
ORDER BY total_revenue DESC;

-- Food Performance

-- 1. Top 10 Restaurants by Orders

SELECT 
    r.restaurant_name,
    COUNT(*) AS total_orders
FROM fact_swiggy_orders f
JOIN dim_restaurant r 
    ON f.restaurant_id = r.restaurant_id
GROUP BY r.restaurant_name
ORDER BY total_orders DESC
LIMIT 10;

-- 2. Top Categories (by Order Volume)

SELECT 
    c.category,
    COUNT(*) AS total_orders
FROM fact_swiggy_orders f
JOIN dim_category c 
    ON f.category_id = c.category_id
GROUP BY c.category
ORDER BY total_orders DESC;


-- 3. Most Ordered Dishes 

SELECT 
    di.dish_name,
    SUM(f.rating_count) AS total_orders
FROM fact_swiggy_orders f
JOIN dim_dish di 
    ON f.dish_id = di.dish_id
GROUP BY di.dish_name
ORDER BY total_orders DESC
LIMIT 10;

-- 4. Cuisine Performance (Orders + Avg Rating)

SELECT 
    c.category,
    COUNT(*) AS total_orders,
    ROUND(AVG(f.rating), 2) AS avg_rating
FROM fact_swiggy_orders f
JOIN dim_category c 
    ON f.category_id = c.category_id
GROUP BY c.category
ORDER BY total_orders DESC;


-- 5. Customer Spending Buckets + Distribution

SELECT 
    CASE 
        WHEN f.price < 100 THEN 'Under 100'
        WHEN f.price BETWEEN 100 AND 199 THEN '100-199'
        WHEN f.price BETWEEN 200 AND 299 THEN '200-299'
        WHEN f.price BETWEEN 300 AND 499 THEN '300-499'
        ELSE '500+'
    END AS spending_bucket,

    COUNT(*) AS total_orders,
    
    ROUND(
        (COUNT(*) * 100.0 / SUM(COUNT(*)) OVER ()), 
    2) AS percentage_distribution

FROM fact_swiggy_orders f

GROUP BY spending_bucket

ORDER BY 
    CASE 
        WHEN spending_bucket = 'Under 100' THEN 1
        WHEN spending_bucket = '100-199' THEN 2
        WHEN spending_bucket = '200-299' THEN 3
        WHEN spending_bucket = '300-499' THEN 4
        ELSE 5
    END;
    
  -- Rating Distribution  
    
SELECT 
    CASE 
        WHEN f.rating >= 1 AND f.rating < 2 THEN '1-2'
        WHEN f.rating >= 2 AND f.rating < 3 THEN '2-3'
        WHEN f.rating >= 3 AND f.rating < 4 THEN '3-4'
        WHEN f.rating >= 4 AND f.rating <= 5 THEN '4-5'
    END AS rating_bucket,

    COUNT(*) AS total_orders,

    ROUND(
        (COUNT(*) * 100.0 / SUM(COUNT(*)) OVER ()), 
    2) AS percentage

FROM fact_swiggy_orders f

GROUP BY rating_bucket

ORDER BY 
    CASE 
        WHEN rating_bucket = '1-2' THEN 1
        WHEN rating_bucket = '2-3' THEN 2
        WHEN rating_bucket = '3-4' THEN 3
        ELSE 4
    END;    
