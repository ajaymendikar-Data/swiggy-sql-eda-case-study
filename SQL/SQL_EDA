-- Finding Null'S-- 

select
sum(case when state is null then 1 else 0 end) as Null_State,
sum(case when City is null then 1 else 0 end) as Null_City,
sum(case when restaurant_name is null then 1 else 0 end) as Null_restaurants,
sum(case when Location is null then 1 else 0 end) as Null_Location,
sum(case when Category is null then 1 else 0 end) as Null_Category,
sum(case when dish_name is null then 1 else 0 end) as Null_Dishs,
sum(case when price is null then 1 else 0 end) as Null_price,
sum(case when Rating is null then 1 else 0 end) as Null_rating,
sum(case when rating_count is null then 1 else 0 end) as Null_Ratingcount,
sum(case when order_date is null then 1 else 0 end) as Null_date
from swiggy_data;

