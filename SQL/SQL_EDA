-- duplicate Detection --

select 
state , city, restaurant_name,location,category,dish_name,price,Rating,rating_count,order_date,
count(*) as CNT 
from swiggy_data
group by state , city, restaurant_name,location,category,dish_name,price,Rating,rating_count,order_date
having count(*) > 1;


-- Delete Duplicates -- 

with CTE as (

select * , row_number() over(partition by
state , city, restaurant_name,location,category,dish_name,price,Rating,rating_count,order_date
order by (select null)
) as RN
from swiggy_data
)
delete from CTE where RN>1;
